{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>Syriiin/renovate-config"
  ],
  "rebaseWhen": "behind-base-branch",
  "packageRules": [
    {
      "matchManagers": [
        "nuget"
      ],
      "matchPackageNames": [
        "xunit*",
        "Microsoft.Net.Test.Sdk"
      ],
      "groupName": "test-tools"
    }
  ],
  "git-submodules": {
    "enabled": true
  }
}
